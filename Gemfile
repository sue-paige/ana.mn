source "https://rubygems.org"

# Local build/preview. GitHub Pages itself builds the site natively on push
# (Settings → Pages → Deploy from a branch) — no CI/Actions required, since the
# only plugins (jekyll-seo-tag, jekyll-sitemap) are on the Pages allowlist.
gem "jekyll", "~> 4.4"

group :jekyll_plugins do
  gem "jekyll-seo-tag", "~> 2.8"
  gem "jekyll-sitemap", "~> 1.4"
end

gem "webrick", "~> 1.8"
